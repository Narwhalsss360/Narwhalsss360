{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "streaming": 100,
    "palette": {
        "primary": "#fafafa",
        "primaryback": "#106335",
        "error": "red",
        "errorback": "#320000",
        "warning": "yellow",
        "warningback": "#000000",
        "info": "cyan",
        "infoback": "#000048",
        "misc": "darkGray",
        "miscback": "#072d18"
    },
    "transient_prompt": {
        "background": "transparent",
        "foreground": "p:misc",
        "template": ""
    },
    "secondary_prompt": {
        "background": "transparent",
        "foreground": "p:primary",
        "template": "  \udb85\udfaa "
    },
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "os",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "foreground_templates": [
                        "{{ if gt .Code 0 }}p:error{{ end }}"
                    ],
                    "background_templates": [
                        "{{ if gt .Code 0 }}p:errorback{{ end }}"
                    ],
                    "style": "diamond",
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "",
                    "template": "{{ if gt .Code 0 }}\uf52f{{ else }}{{ if .WSL }}\ue62a\udb81\udf98{{ end }}{{.Icon}}{{ end }} "
                },
                {
                    "type": "session",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "background_templates": [
                        "{{ if gt .Code 0 }}p:errorback{{ end }}"
                    ],
                    "style": "diamond",
                    "template": "{{ if .SSHSession }} {{ end }}"
                },
                {
                    "type": "path",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "background_templates": [
                        "{{ if gt .Code 0 }}p:errorback{{ end }}"
                    ],
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "",
                    "template": "{{ .Path }} ",
                    "options": {
                        "style": "agnoster",
                        "folder_icon": "\uea83",
                        "folder_separator_icon": "\uea9f",
                        "home_icon": "\ueb06",
                        "mapped_locations": {
                            "~/Source": "\uebdf",
                            "~/src": "\uebdf",
                            "~/Source/Arduino": "\uf34b",
                            "~/src/micro/arduino": "\uf34b",
                            "~/Source/Repositories/Narwhalsss360/": "\ueace",
                            "~/src/repos/Narwhalsss360/": "\ueace",
                            "~/OneDrive": "\udb80\udfca"
                        }
                    }
                },
                {
                    "type": "git",
                    "style": "diamond",
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "\ue0b4 ",
                    "foreground": "p:misc",
                    "background": "p:miscback",
                    "foreground_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}p:warning{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:error{{ end }}",
                        "{{ if .Detached }}p:warning{{ end }}",
                        "{{ if gt .Ahead 0 }}p:info{{ end }}",
                        "{{ if gt .Behind 0 }}p:error{{ end }}"
                    ],
                    "background_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}p:warningback{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:errorback{{ end }}",
                        "{{ if .Detached }}p:warningback{{ end }}",
                        "{{ if gt .Ahead 0 }}p:infoback{{ end }}",
                        "{{ if gt .Behind 0 }}p:errorback{{ end }}"
                    ],
                    "template": "{{ .UpstreamIcon }} {{ if .Detached }}<f>\uf4b6{{ trunc 7 .Commit.Sha }}</f>{{ else }}{{ .HEAD }}{{ end }}{{ if gt .Behind 0 }}<f>{{ end }} {{ if .BranchStatus }}{{ .BranchStatus }}{{ end }}{{ if and (gt .Ahead 0) (gt .Behind 0) }} \udb81\udd5a {{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}{{ if gt .Behind 0 }}</f>{{ end }}",
                    "options": {
                        "fetch_status": true,
                        "fetch_upstream_icon": true,
                        "branch_identical_icon": "\udb85\udf4d",
                        "branch_gone_icon": "\udb85\udf62"
                    }
                },
                {
                    "type": "python",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "\ue0b4 ",
                    "background": "#fff45e",
                    "foreground": "#2c426e",
                    "template": " {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{ end }}",
                    "options": {
                        "display_mode": "files"
                    }
                },
                {
                    "type": "zig",
                    "style": "diamond",
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "\ue0b4 ",
                    "background": "black",
                    "foreground": "#ff9f19",
                    "template": " {{ if .Error }}\uea76{{ else }}{{ .Full }}{{ end }}"
                },
                {
                    "type": "dotnet",
                    "style": "diamond",
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "\ue0b4 ",
                    "background": "#202020",
                    "foreground": "#7d2bd4",
                    "template": " {{ .Full }}",
                    "options": {
                        "fetch_version": true
                    }
                },
                {
                    "type": "battery",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "\ue0b4 ",
                    "foreground": "p:error",
                    "background": "p:errorback",
                    "template": "{{ if eq \"Discharging\" .State.String }}{{ .Icon }}{{ .Percentage }}%{{ end }}",
                    "options": {
                        "discharging_icon": "\udb85\udfde"
                    }
                },
                {
                    "type": "upgrade",
                    "style": "diamond",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "template": "<f>\udb81\udeb0 {{ .Current }}/{{ .Latest }}</f> "
                },
                {
                    "type": "root",
                    "style": "diamond",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "template": "\uD83D\uDDDD "
                },
                {
                    "type": "status",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "\ue0b4",
                    "background": "p:errorback",
                    "foreground": "p:error",
                    "template": "{{ .String }} "
                },
                {
                    "type": "shell",
                    "style": "diamond",
                    "foreground": "p:primary",
                    "background": "p:primaryback",
                    "trailing_diamond": "",
                    "options": {
                        "mapped_shell_names": {
                            "pwsh": "",
                            "fish": ""
                        }
                    }
                }
            ]
        }
    ],
    "version": 3
}
